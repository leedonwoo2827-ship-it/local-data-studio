# Local Data Studio — 환경변수 예시
# 이 파일을 복사해 .env 로 저장한 뒤 값을 채우세요.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
#
# 또는 키트의 bootstrap.ps1 / bootstrap.sh 를 실행하면 시스템 환경변수로 자동 등록됩니다.
# (이 경우 .env 는 없어도 됩니다.)

# Ubion LiteLLM 프록시 주소 (사내망)
UBION_LITELLM_URL=http://192.168.50.119:4000

# 본인 virtual key (관리자 발급).
# 개발/테스트용 키는 다음 파일에 있습니다:
#   ../_context/Ubion_liteLLM_Migration_Kit/test_dev_api_key.txt
UBION_LITELLM_KEY=sk-...your-virtual-key...

# 사용할 LLM 모델 (기본: deepseek-v4-flash)
# 추론 과정이 필요하면 deepseek-v4-flash-think 로 변경 가능
LDS_MODEL=deepseek-v4-flash
